# YouTube OAuth2 - Download from Google Cloud Console
YOUTUBE_CLIENT_SECRET_PATH=config/youtube_client_secret.json

# TikTok App Credentials - From TikTok for Developers
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Instagram - Personal account credentials
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# Optional: master PIN for encrypting credentials file (default: machine UUID)
UPLOADER_ENCRYPTION_PIN=
